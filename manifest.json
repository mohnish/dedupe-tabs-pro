{
  "manifest_version": 3,
  "name": "Dedupe Tabs Pro",
  "description": "Close duplicate browser tabs by URL.",
  "version": "1.0.0",
  "author": "Mohnish Thallavajhula",
  "permissions": ["storage", "tabs"],
  "action": {
    "default_title": "Review duplicate tabs",
    "default_popup": "src/popup.html"
  },
  "commands": {
    "close-all-duplicates": {
      "suggested_key": {
        "default": "Alt+Shift+D",
        "mac": "Option+Shift+D"
      },
      "description": "Close duplicate tabs"
    }
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "options_ui": {
    "page": "src/options.html",
    "open_in_tab": true
  }
}
